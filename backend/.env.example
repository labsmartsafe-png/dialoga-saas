# =========================================
# dIAloga+ SaaS - Variáveis de Ambiente
# Copie para .env e ajuste os valores
# =========================================

# Ambiente
APP_ENV=development
DEBUG=True

# Segurança
SECRET_KEY=troque-esta-chave-secreta-por-uma-aleatoria-de-64-caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=43200  # 30 dias

# Banco de dados
# Para SQLite (dev/testes):
DATABASE_URL=sqlite:///./data/dialoga.db
# Para PostgreSQL (produção):
# DATABASE_URL=postgresql://user:password@localhost:5432/dialoga

# CORS - origens permitidas separadas por vírgula
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5500,http://127.0.0.1:5500,http://127.0.0.1:8000

# Servidor
HOST=0.0.0.0
PORT=8000

# WhatsApp Cloud API (Meta) - OPCIONAL no MVP
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_TOKEN=seu-token-aqui
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=qualquer-string-para-verificacao

# Limites
MAX_UPLOAD_MB=10
RATE_LIMIT_PER_MINUTE=60
